test_endpoint "PUT" "/api/admin/tenants/${TN_ID:-null}/users/${U_ID:-null}" "$TENANT_DATA" "PUT /api/admin/tenants/{tenant_id}/users/{user_id}" "$ADMIN_TOKEN" "ADMIN_PANEL" "$TN_ID"
